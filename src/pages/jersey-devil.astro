    <div class="doc-title">The Jersey Devil</div>
    <p class="doc-subtitle"><em>It has been screaming over the pines for nearly three hundred years. People keep hearing it.</em></p>
    <div class="danger-meter">
      <div class="danger-label-col"><div class="danger-title">Monster Danger Index</div><div class="danger-name">AERIAL THREAT</div></div>
      <div class="danger-bars"><div class="bar filled"></div><div class="bar filled"></div><div class="bar filled"></div><div class="bar filled"></div><div class="bar filled"></div><div class="bar filled"></div><div class="bar filled"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div></div>
