---
import { getCollection } from 'astro:content';
import FieldManual from '../layouts/FieldManual.astro';
import StampRow from '../components/StampRow.astro';
import DocMeta from '../components/DocMeta.astro';
import DocTitle from '../components/DocTitle.astro';
import Section from '../components/Section.astro';
import {
  WORLD_LAND_PATH,
  WORLD_VIEWBOX,
  WORLD_WIDTH,
  WORLD_HEIGHT,
  projectLatLon,
} from '../lib/world-map.ts';
import '../styles/pages/sightings.css';

const now = new Date();
const all = (await getCollection('monsters', ({ data }) => data.status === 'published'))
  .filter((e) => !e.data.publishDate || e.data.publishDate <= now)
  .sort((a, b) => parseInt(a.data.number, 10) - parseInt(b.data.number, 10));

interface PinnedSighting {
  monsterId: string;
  monsterTitle: string;
  monsterColor: string;
  number: string;
  name: string;
  year?: number | string;
  label?: string;
  x: number;
  y: number;
}

const pins: PinnedSighting[] = [];
for (const entry of all) {
  for (const s of entry.data.sightings) {
    const point = projectLatLon(s.lat, s.lon);
    if (!point) continue;
    pins.push({
      monsterId: entry.id,
      monsterTitle: entry.data.title,
      monsterColor: entry.data.bandColor,
      number: entry.data.number,
      name: s.name,
      year: s.year,
      label: s.label,
      x: point.x,
      y: point.y,
    });
  }
}

const mapped = all.filter((e) => e.data.sightings.length > 0);
const unmapped = all.filter((e) => e.data.sightings.length === 0);
---

<FieldManual
  title="Where Reported"
  description="Every documented sighting in the Monster Survival Guide, plotted on a world map. Each pin is colour-coded by monster."
  classification="monster survival guide  —  where reported"
  bottomBar="monster survival guide  ·  field map  ·  season one"
>
  <StampRow red="Where Reported" faded="World Map" blue="Documented Encounters" />
  <DocMeta
    rows={[
      { label: 'DOCUMENT TYPE', value: 'Field Map — All Reported Sightings' },
      { label: 'PINS PLACED', value: `${pins.length} across ${mapped.length} entries` },
      { label: 'PROJECTION', value: 'Equirectangular · world land outline (Natural Earth 110m)' },
      { label: 'STATUS', value: 'Open Distribution — Updated as Entries Add Locations' },
    ]}
  />
  <DocTitle subtitle="Every documented sighting, on one map. Colour-coded by monster.">
    Where<br />Reported
  </DocTitle>

  <Section heading="The Field Map">
    <p>
      Every entry in the guide carries a list of documented locations. They are plotted below —
      colour-coded by monster — so you can see where the encounter record clusters across the world.
    </p>

    <div class="combined-map-frame">
      <svg
        class="combined-map-svg"
        viewBox={WORLD_VIEWBOX}
        role="img"
        aria-label={`World map with ${pins.length} pins.`}
      >
        <g class="combined-map-grid" aria-hidden="true">
          {
            Array.from({ length: 7 }, (_, i) => (
              <line
                x1={0}
                y1={(i * WORLD_HEIGHT) / 6}
                x2={WORLD_WIDTH}
                y2={(i * WORLD_HEIGHT) / 6}
              />
            ))
          }
          {
            Array.from({ length: 13 }, (_, i) => (
              <line
                x1={(i * WORLD_WIDTH) / 12}
                y1={0}
                x2={(i * WORLD_WIDTH) / 12}
                y2={WORLD_HEIGHT}
              />
            ))
          }
        </g>

        <path class="combined-map-land" d={WORLD_LAND_PATH}></path>

        {
          pins.map((p) => (
            <a class="combined-map-pin-link" href={`/${p.monsterId}`}>
              <circle class="combined-map-halo" cx={p.x} cy={p.y} r={9} />
              <circle
                class="combined-map-pin"
                cx={p.x}
                cy={p.y}
                r={5}
                style={`fill: ${p.monsterColor};`}
              />
              <title>
                {p.monsterTitle} — {p.name}
                {p.year ? ` (${p.year})` : ''}
                {p.label ? ` · ${p.label}` : ''}
              </title>
            </a>
          ))
        }
      </svg>
    </div>

    <ol class="combined-map-legend" aria-label="Legend">
      {
        mapped.map((entry) => (
          <li>
            <a href={`/${entry.id}`}>
              <span
                class="legend-swatch"
                aria-hidden="true"
                style={`background: ${entry.data.bandColor};`}
              />
              <span class="legend-num">{entry.data.number}</span>
              <span class="legend-name">{entry.data.title}</span>
              <span class="legend-count">
                {entry.data.sightings.length} {entry.data.sightings.length === 1 ? 'pin' : 'pins'}
              </span>
            </a>
          </li>
        ))
      }
    </ol>

    {
      unmapped.length > 0 && (
        <p class="combined-map-unmapped">
          Not on the map: {unmapped.map((e) => e.data.title).join(' · ')}. These entries are
          explicitly placeless — modern folklore with no anchoring geography.
        </p>
      )
    }
  </Section>

  <Section heading="What the Map Shows You">
    <p>
      The pins cluster heavily in North America — a function of which traditions this Season has
      covered, not a claim about the underlying record. The Wendigo lineage extends from Alberta
      across the boreal forest. The Mothman lights up the Ohio River valley. The Black-Eyed Children
      show the coastal-threshold pattern that runs from Texas to the English east coast. The
      Skinwalker pins are placed in the Diné homeland and at the Uintah Basin property the press has
      tied to it — a connection many Diné people contest, and we have flagged accordingly.
    </p>
    <p>
      As the guide grows the map will too. If you have an account anchored to a place that isn't
      here yet, <a href="/about#contact--corrections"
        >tell us — we'd rather get the record right than be right by accident.</a
      >
    </p>
  </Section>
</FieldManual>
