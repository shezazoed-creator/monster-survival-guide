<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Monster Index</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Sorts+Mill+Goudy:ital@0;1&family=Anonymous+Pro:ital@0;1&display=swap" rel="stylesheet"/>
<style>
  :root {
    --paper: #f0ead8;
    --aged: #e4dcc8;
    --ink: #1a1610;
    --faded: #5a5040;
    --stamp-red: #8b1a0a;
    --stamp-blue: #1a3a6a;
    --redact: #111108;
    --margin: #9a8a6a;
    --rule: rgba(26,22,16,0.12);
    --warn: #8b1a0a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background-color: #1e1a14;
    font-family: 'Sorts Mill Goudy', Georgia, serif;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 16px 80px;
    position: relative;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .document {
    background-color: var(--paper);
    max-width: 780px;
    width: 100%;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.3), 4px 4px 0 rgba(0,0,0,0.2), 8px 8px 0 rgba(0,0,0,0.12), 0 30px 80px rgba(0,0,0,0.6);
    animation: docReveal 1.2s ease both;
  }

  @keyframes docReveal {
    from { opacity: 0; transform: translateY(30px) rotate(-0.5deg); }
    to { opacity: 1; transform: translateY(0) rotate(0deg); }
  }

  .document::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='p'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23p)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .document::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(to bottom, transparent 0px, transparent 31px, var(--rule) 31px, var(--rule) 32px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  /* Classification bar */
  .classification-bar {
    background: var(--redact);
    color: #d4c8a0;
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.35em;
    text-align: center;
    padding: 7px 0;
    text-transform: uppercase;
    animation: fadeIn 0.8s ease both 0.3s;
  }

  .doc-inner {
    padding: 52px 56px 72px 120px;
    position: relative;
    z-index: 1;
  }

  /* Red margin line */
  .doc-inner::before {
    content: '';
    position: absolute;
    top: 0; bottom: 0; left: 88px;
    width: 1.5px;
    background: rgba(180,60,40,0.5);
  }

  /* Stamp row */
  .stamp-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 10px;
    animation: fadeIn 0.8s ease both 0.5s;
  }
  .stamp {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: 2px solid;
    padding: 4px 10px;
    opacity: 0.7;
  }
  .stamp.red { color: var(--stamp-red); border-color: var(--stamp-red); transform: rotate(-4deg); }
  .stamp.blue { color: var(--stamp-blue); border-color: var(--stamp-blue); transform: rotate(2deg); }
  .stamp.faded { color: var(--margin); border-color: var(--margin); transform: rotate(-1deg); opacity: 0.45; font-size: 0.6rem; }

  /* Doc meta */
  .doc-meta {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.65rem;
    color: var(--faded);
    line-height: 1.8;
    border-bottom: 1px solid rgba(26,22,16,0.12);
    padding-bottom: 18px;
    margin-bottom: 28px;
    animation: fadeIn 0.8s ease both 0.6s;
  }
  .doc-meta span { color: var(--ink); font-weight: bold; }

  /* Title */
  .doc-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(2.8rem, 8vw, 5rem);
    line-height: 1.0;
    color: var(--ink);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 6px;
    animation: fadeIn 1s ease both 0.7s;
  }
  .doc-subtitle {
    font-family: 'Sorts Mill Goudy', Georgia, serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--faded);
    margin-bottom: 40px;
    animation: fadeIn 1s ease both 0.8s;
  }

  /* Section head */
  .section-head {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    color: var(--faded);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-head::before { content: ''; width: 18px; height: 1px; background: var(--warn); opacity: 0.5; flex-shrink: 0; }
  .section-head::after { content: ''; flex: 1; height: 1px; background: var(--rule); }

  p { font-size: 1.05rem; line-height: 1.9; color: var(--ink); margin-bottom: 18px; }

  /* ── ENTRY CARDS ── */
  .entry-list { display: flex; flex-direction: column; gap: 0; margin: 8px 0 44px; }

  .entry-card {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(26,22,16,0.14);
    border-bottom: none;
    background: var(--aged);
    text-decoration: none;
    color: var(--ink);
    transition: background 0.18s;
    position: relative;
    overflow: hidden;
  }
  .entry-card:last-child { border-bottom: 1px solid rgba(26,22,16,0.14); }
  .entry-card:hover { background: #ddd5be; }
  .entry-card:hover .entry-arrow { opacity: 1; transform: translateX(0); }

  /* Left threat-level colour band */
  .entry-band {
    width: 5px;
    flex-shrink: 0;
  }

  .entry-body {
    flex: 1;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .entry-label {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.26em;
    color: var(--margin);
    text-transform: uppercase;
  }

  .entry-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: 0.03em;
    color: var(--ink);
    line-height: 1.15;
  }

  .entry-desc {
    font-family: 'Sorts Mill Goudy', Georgia, serif;
    font-style: italic;
    font-size: 0.88rem;
    color: var(--faded);
    line-height: 1.5;
    margin-top: 2px;
  }

  .entry-meta {
    display: flex;
    gap: 12px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .entry-tag {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--margin);
    border: 1px solid rgba(26,22,16,0.15);
    padding: 2px 7px;
    background: rgba(26,22,16,0.03);
  }

  .entry-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    padding: 16px 20px 16px 0;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Danger index mini bar */
  .mini-index {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .mini-label {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.18em;
    color: var(--margin);
    text-transform: uppercase;
  }
  .mini-bars {
    display: flex;
    gap: 2px;
  }
  .mbar {
    width: 8px;
    height: 8px;
    border: 1px solid rgba(26,22,16,0.14);
    background: rgba(26,22,16,0.04);
  }
  .mbar.f { background: var(--warn); border-color: var(--warn); }

  .entry-arrow {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.85rem;
    color: var(--warn);
    opacity: 0.4;
    transform: translateX(-4px);
    transition: opacity 0.18s, transform 0.18s;
    margin-top: 4px;
  }

  /* Pilot / about card — special style */
  .entry-card.about {
    background: rgba(26,22,16,0.04);
    border-color: rgba(26,22,16,0.18);
  }
  .entry-card.about:hover { background: rgba(26,22,16,0.08); }

  /* Divider */
  .divider {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(26,22,16,0.15), transparent);
    margin: 32px 0;
  }

  /* Sign-off */
  .sign-off-block {
    margin-top: 44px;
    padding-top: 22px;
    border-top: 1px solid rgba(26,22,16,0.1);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
  }
  .sig-left { font-family: 'Anonymous Pro', monospace; font-size: 0.62rem; color: var(--faded); line-height: 1.8; }
  .sig-name { font-family: 'Sorts Mill Goudy', Georgia, serif; font-style: italic; font-size: 1.5rem; color: var(--ink); opacity: 0.5; display: block; margin-top: 4px; }
  .sig-right { font-family: 'Anonymous Pro', monospace; font-size: 0.58rem; color: rgba(26,22,16,0.3); text-align: right; line-height: 1.8; text-transform: uppercase; letter-spacing: 0.1em; }

  /* Social */
  .social-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }
  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--faded);
    border: 1px solid rgba(26,22,16,0.15);
    padding: 7px 9px;
    background: rgba(26,22,16,0.04);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .social-btn svg { width: 14px; height: 14px; flex-shrink: 0; }
  .social-btn:hover { background: rgba(26,22,16,0.08); color: var(--ink); border-color: rgba(26,22,16,0.25); }

  /* Bottom bar */
  .bottom-bar {
    background: var(--redact);
    color: #d4c8a0;
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-align: center;
    padding: 7px 0;
    text-transform: uppercase;
  }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

  .entry-card { animation: fadeUp 0.6s ease both; }
  .entry-card:nth-child(1) { animation-delay: 0.85s; }
  .entry-card:nth-child(2) { animation-delay: 0.95s; }
  .entry-card:nth-child(3) { animation-delay: 1.05s; }
  .entry-card:nth-child(4) { animation-delay: 1.15s; }
  .entry-card:nth-child(5) { animation-delay: 1.25s; }
  .entry-card:nth-child(6) { animation-delay: 1.35s; }

  @media (max-width: 600px) {
    .doc-inner { padding: 36px 24px 52px 80px; }
    .doc-inner::before { left: 56px; }
    .stamp-row { flex-wrap: wrap; gap: 10px; }
    .entry-right { display: none; }
  }
</style>
</head>
<body>

<div class="document">
  <div class="classification-bar">◆ &nbsp; monster survival guide &nbsp;—&nbsp; menu &nbsp; ◆</div>

  <div class="doc-inner">

    <div class="stamp-row">
      <div class="stamp red">All Entries</div>
      <div class="stamp faded">Season One</div>
      <div class="stamp blue">Field Manual</div>
    </div>

    <div class="doc-meta">
      <div>DOCUMENT TYPE: &nbsp;<span>Index — All Survival Guide Entries</span></div>
      <div>SEASON: &nbsp;<span>One — Currently Active</span></div>
      <div>ENTRIES: &nbsp;<span>5 Filed — More Incoming</span></div>
      <div>STATUS: &nbsp;<span>Open Distribution — Read Before You Need To</span></div>
    </div>

    <div class="doc-title">All<br/>Entries</div>
    <p class="doc-subtitle"><em>Every survival guide filed so far. Start anywhere. Read everything.</em></p>

    <!-- START HERE -->
    <div class="section-head">Start Here</div>
    <div class="entry-list">
      <a class="entry-card about" href="/">
        <div class="entry-band" style="background: rgba(26,22,16,0.25);"></div>
        <div class="entry-body">
          <div class="entry-label">Introduction · Field Manual</div>
          <div class="entry-title">About This Guide</div>
          <div class="entry-desc">What this is, how it works, and why you should read it before you need it.</div>
          <div class="entry-meta">
            <span class="entry-tag">How to use</span>
            <span class="entry-tag">Danger index explained</span>
            <span class="entry-tag">Season one overview</span>
          </div>
        </div>
        <div class="entry-right">
          <div class="mini-index">
            <div class="mini-label">No threat entity</div>
          </div>
          <div class="entry-arrow">→</div>
        </div>
      </a>
    </div>

    <hr class="divider"/>

    <!-- SEASON ONE ENTRIES -->
    <div class="section-head">Season One — Survival Entries</div>
    <div class="entry-list">

      <!-- Wendigo -->
      <a class="entry-card" href="/wendigo">
        <div class="entry-band" style="background: #1a5080;"></div>
        <div class="entry-body">
          <div class="entry-label">Entry 01 · Ancient Threat · Boreal Forests</div>
          <div class="entry-title">The Wendigo</div>
          <div class="entry-desc">It was human once. That is the part that should terrify you.</div>
          <div class="entry-meta">
            <span class="entry-tag">Algonquian tradition</span>
            <span class="entry-tag">Possession risk</span>
            <span class="entry-tag">Winter threat</span>
          </div>
        </div>
        <div class="entry-right">
          <div class="mini-index">
            <div class="mini-label">Danger · 9/10</div>
            <div class="mini-bars">
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div>
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar"></div>
            </div>
          </div>
          <div class="entry-arrow">→</div>
        </div>
      </a>

      <!-- Slenderman -->
      <a class="entry-card" href="/slenderman">
        <div class="entry-band" style="background: #8b1a0a;"></div>
        <div class="entry-body">
          <div class="entry-label">Entry 02 · Absolute Threat · No Geography</div>
          <div class="entry-title">Slenderman</div>
          <div class="entry-desc">He is already watching. He has always been watching.</div>
          <div class="entry-meta">
            <span class="entry-tag">Digital origin</span>
            <span class="entry-tag">Proxy syndrome</span>
            <span class="entry-tag">No confirmed counters</span>
          </div>
        </div>
        <div class="entry-right">
          <div class="mini-index">
            <div class="mini-label">Danger · 10/10</div>
            <div class="mini-bars">
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div>
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div>
            </div>
          </div>
          <div class="entry-arrow">→</div>
        </div>
      </a>

      <!-- Black-Eyed Children -->
      <a class="entry-card" href="/black-eyed-children">
        <div class="entry-band" style="background: #1a3050;"></div>
        <div class="entry-body">
          <div class="entry-label">Entry 03 · Threshold Threat · Coastal Pattern</div>
          <div class="entry-title">Black-Eyed Children</div>
          <div class="entry-desc">They only want to come inside. They will keep asking until you let them.</div>
