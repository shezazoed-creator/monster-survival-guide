            <div class="mini-bars">
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div>
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar"></div><div class="mbar"></div><div class="mbar"></div>
