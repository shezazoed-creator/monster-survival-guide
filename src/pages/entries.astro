            <span class="entry-tag">Invitation required</span>
            <span class="entry-tag">Coastal reports</span>
            <span class="entry-tag">Global sightings</span>
          </div>
        </div>
        <div class="entry-right">
          <div class="mini-index">
            <div class="mini-label">Danger · 7/10</div>
            <div class="mini-bars">
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div>
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar"></div><div class="mbar"></div><div class="mbar"></div>
            </div>
          </div>
          <div class="entry-arrow">→</div>
        </div>
      </a>

      <!-- Mothman -->
      <a class="entry-card" href="/mothman">
        <div class="entry-band" style="background: #804010;"></div>
        <div class="entry-body">
          <div class="entry-label">Entry 03 (Alt) · Harbinger Class · Point Pleasant WV</div>
          <div class="entry-title">The Mothman</div>
          <div class="entry-desc">It does not hunt you. It watches you. And where it watches, things collapse.</div>
          <div class="entry-meta">
            <span class="entry-tag">Prophetic appearance</span>
            <span class="entry-tag">Bridge warning</span>
            <span class="entry-tag">46 dead</span>
          </div>
        </div>
        <div class="entry-right">
          <div class="mini-index">
            <div class="mini-label">Danger · 8/10</div>
            <div class="mini-bars">
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div>
              <div class="mbar f"></div><div class="mbar f"></div><div class="mbar f"></div><div class="mbar"></div><div class="mbar"></div>
            </div>
          </div>
          <div class="entry-arrow">→</div>
        </div>
      </a>

      <!-- Coming Soon -->
      <div class="entry-card" style="opacity:0.4; cursor:default; pointer-events:none;">
        <div class="entry-band" style="background: rgba(26,22,16,0.2);"></div>
        <div class="entry-body">
          <div class="entry-label">Entry 04 · Coming Soon</div>
          <div class="entry-title">Unknown Entity</div>
          <div class="entry-desc">The next entry is being prepared. Check back soon.</div>
          <div class="entry-meta">
            <span class="entry-tag">Pending</span>
          </div>
        </div>
        <div class="entry-right">
          <div class="mini-index">
            <div class="mini-label">Classified</div>
            <div class="mini-bars">
              <div class="mbar"></div><div class="mbar"></div><div class="mbar"></div><div class="mbar"></div><div class="mbar"></div>
              <div class="mbar"></div><div class="mbar"></div><div class="mbar"></div><div class="mbar"></div><div class="mbar"></div>
            </div>
          </div>
          <div class="entry-arrow" style="opacity:0.2;">→</div>
        </div>
      </div>

    </div>

    <!-- SIGN OFF -->
    <div class="sign-off-block">
      <div class="sig-left">
        Monster Survival Guide<br/>
        <span class="sig-name">Zazu</span>
        <span style="font-family:'Anonymous Pro',monospace;font-size:0.58rem;color:var(--margin);">Identification · Survival · Documented Accounts</span>
        <div class="social-row">
          <a href="#" class="social-btn" aria-label="YouTube">
