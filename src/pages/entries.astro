---
import { getCollection } from 'astro:content';
import FieldManual from '../layouts/FieldManual.astro';
import StampRow from '../components/StampRow.astro';
import DocMeta from '../components/DocMeta.astro';
import DocTitle from '../components/DocTitle.astro';
import { upcoming } from '../config/site.ts';
import { groupBySeason, seasonRoman } from '../lib/seasons.ts';
import '../styles/pages/entries.css';

const now = new Date();
const entries = (await getCollection('monsters', ({ data }) => data.status === 'published'))
  .filter((e) => !e.data.publishDate || e.data.publishDate <= now)
  .sort((a, b) => parseInt(a.data.number, 10) - parseInt(b.data.number, 10));

const seasonGroups = groupBySeason(entries);

// Build the unique tag list for the filter UI.
const allTags = Array.from(new Set(entries.flatMap((e) => e.data.tags))).sort();

// Danger bands shown in the filter UI.
const dangerBands = [
  { label: '1–4', min: 1, max: 4 },
  { label: '5–6', min: 5, max: 6 },
  { label: '7–8', min: 7, max: 8 },
  { label: '9–10', min: 9, max: 10 },
];
---

<FieldManual
  title="Monster Index"
  description="Every Monster Survival Guide entry filed so far. Start anywhere. Read everything."
  classification="monster survival guide  —  menu"
  bottomBar="monster survival guide  ·  all entries  ·  season one"
>
  <StampRow red="All Entries" faded="Season One" blue="Field Manual" />
  <DocMeta
    rows={[
      { label: 'DOCUMENT TYPE', value: 'Index — All Survival Guide Journal Entries' },
      { label: 'SEASON', value: 'One — Currently Active' },
      { label: 'ENTRIES', value: `${entries.length} Filed — More Incoming` },
      { label: 'STATUS', value: 'Open Distribution — Read Before You Need To' },
    ]}
  />
  <DocTitle subtitle="Every survival guide filed so far. Start anywhere. Read everything.">
    All<br />Entries
  </DocTitle>

  <h2 class="section-head">Start Here</h2>
  <div class="entry-list">
    <a class="entry-card about" href="/">
      <div class="entry-band" style="background: rgba(26,22,16,0.25);"></div>
      <div class="entry-body">
        <div class="entry-label">Introduction · Field Manual</div>
        <h3 class="entry-title">About This Guide</h3>
        <div class="entry-desc">
          What this is, how it works, and why you should read it before you need it.
        </div>
        <div class="entry-meta">
          <span class="entry-tag">How to use</span>
          <span class="entry-tag">Danger index explained</span>
          <span class="entry-tag">Season one overview</span>
        </div>
      </div>
      <div class="entry-right">
        <div class="mini-index">
          <div class="mini-label">No threat entity</div>
        </div>
        <div class="entry-arrow">→</div>
      </div>
    </a>
  </div>

  <hr class="divider" />

  <p class="season-nav-row" aria-label="Browse by season">
    <span class="season-nav-label">Browse by season:</span>
    {
      seasonGroups.map((g) => (
        <a class="season-nav-chip" href={`/seasons/${g.season}`}>
          Season {seasonRoman(g.season)} ({g.entries.length})
        </a>
      ))
    }
  </p>

  <h2 class="section-head">All Survival Entries</h2>

  <label class="filter-search" for="entries-search">
    <span class="visually-hidden">Search entries</span>
    <svg viewBox="0 0 24 24" aria-hidden="true" class="filter-search-icon">
      <circle cx="11" cy="11" r="6" fill="none" stroke="currentColor" stroke-width="2"></circle>
      <line
        x1="15.5"
        y1="15.5"
        x2="20"
        y2="20"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"></line>
    </svg>
    <input
      id="entries-search"
      type="search"
      placeholder="Search by name, region, tag, or description…"
      autocomplete="off"
      data-search
    />
    <button
      type="button"
      class="filter-search-clear"
      data-search-clear
      aria-label="Clear search"
      hidden
    >
      ×
    </button>
  </label>

  <div class="filter-bar" data-filter-bar>
    <fieldset class="filter-group">
      <legend class="filter-legend">Danger</legend>
      <button type="button" class="filter-chip is-active" data-filter="danger" data-value="all">
        All
      </button>
      {
        dangerBands.map((band) => (
          <button
            type="button"
            class="filter-chip"
            data-filter="danger"
            data-min={band.min}
            data-max={band.max}
          >
            {band.label}
          </button>
        ))
      }
    </fieldset>

    <fieldset class="filter-group filter-group--tags">
      <legend class="filter-legend">Tag</legend>
      <button type="button" class="filter-chip is-active" data-filter="tag" data-value="all">
        All
      </button>
      {
        allTags.map((tag, i) => (
          <button
            type="button"
            class="filter-chip"
            data-filter="tag"
            data-value={tag}
            data-tag-rest={i >= 5 ? '' : null}
            hidden={i >= 5 ? true : null}
          >
            {tag}
          </button>
        ))
      }
      {
        allTags.length > 5 && (
          <button type="button" class="filter-toggle" data-tag-toggle aria-expanded="false">
            <span data-tag-toggle-show>Show all {allTags.length}</span>
            <span data-tag-toggle-hide hidden>
              Show fewer
            </span>
          </button>
        )
      }
    </fieldset>

    <button type="button" class="filter-clear" data-filter-clear>Reset</button>
  </div>

  <p class="filter-empty" data-filter-empty hidden>No entries match this combination of filters.</p>

  <div class="entry-list" data-entry-list>
    {
      entries.map((e) => (
        <a
          class="entry-card"
          href={`/${e.id}`}
          data-card
          data-danger={e.data.danger}
          data-tags={e.data.tags.join('|')}
          data-search-text={[
            e.data.title,
            e.data.description,
            e.data.entryClass,
            e.data.region,
            e.data.tags.join(' '),
          ]
            .join(' ')
            .toLowerCase()}
        >
          <div class="entry-band" style={`background: ${e.data.bandColor};`} />
          <div class="entry-body">
            <div class="entry-label">
              Entry {e.data.number} · {e.data.entryClass} · {e.data.region}
            </div>
            <h3 class="entry-title">{e.data.title}</h3>
            <div class="entry-desc">{e.data.description}</div>
            <div class="entry-meta">
              {e.data.tags.map((t) => (
                <span class="entry-tag">{t}</span>
              ))}
            </div>
          </div>
          <div class="entry-right">
            <div class="mini-index">
              <div class="mini-label">Danger · {e.data.danger}/10</div>
              <div class="mini-bars" role="img" aria-label={`Danger ${e.data.danger} out of 10`}>
                {Array.from({ length: 10 }).map((_, i) => (
                  <div class={i < e.data.danger ? 'mbar f' : 'mbar'} aria-hidden="true" />
                ))}
              </div>
            </div>
            <div class="entry-arrow">→</div>
          </div>
        </a>
      ))
    }

    {
      upcoming && (
        <div class="entry-card coming-soon" data-coming-soon>
          <div class="entry-band" style="background: rgba(26,22,16,0.2);" />
          <div class="entry-body">
            <div class="entry-label">{upcoming.label}</div>
            <h3 class="entry-title">{upcoming.title}</h3>
            <div class="entry-desc">{upcoming.description}</div>
            <div class="entry-meta">
              <span class="entry-tag">Pending</span>
            </div>
          </div>
          <div class="entry-right">
            <div class="mini-index">
              <div class="mini-label">Classified</div>
              <div class="mini-bars" aria-hidden="true">
                {Array.from({ length: 10 }).map(() => (
                  <div class="mbar" />
                ))}
              </div>
            </div>
            <div class="entry-arrow" style="opacity:0.2;">
              →
            </div>
          </div>
        </div>
      )
    }
  </div>
</FieldManual>

<script>
  // Search + tag + danger filtering. No build-time dependency — operates on
  // data attributes baked into each card. All three filters AND together.
  const bar = document.querySelector<HTMLElement>('[data-filter-bar]');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-card]'));
  const comingSoon = document.querySelector<HTMLElement>('[data-coming-soon]');
  const empty = document.querySelector<HTMLElement>('[data-filter-empty]');
  const searchInput = document.querySelector<HTMLInputElement>('[data-search]');
  const searchClear = document.querySelector<HTMLButtonElement>('[data-search-clear]');
  const tagRestChips = Array.from(document.querySelectorAll<HTMLElement>('[data-tag-rest]'));
  const tagToggle = document.querySelector<HTMLButtonElement>('[data-tag-toggle]');
  const tagToggleShow = document.querySelector<HTMLElement>('[data-tag-toggle-show]');
  const tagToggleHide = document.querySelector<HTMLElement>('[data-tag-toggle-hide]');

  const state: {
    danger: { min: number; max: number } | null;
    tag: string | null;
    search: string;
  } = { danger: null, tag: null, search: '' };

  function applyFilters() {
    let visible = 0;
    for (const card of cards) {
      const danger = Number(card.dataset.danger);
      const tags = (card.dataset.tags ?? '').split('|');
      const text = card.dataset.searchText ?? '';

      const matchDanger =
        !state.danger || (danger >= state.danger.min && danger <= state.danger.max);
      const matchTag = !state.tag || tags.includes(state.tag);
      const matchSearch = !state.search || text.includes(state.search);
      const show = matchDanger && matchTag && matchSearch;
      card.toggleAttribute('hidden', !show);
      if (show) visible++;
    }
    if (comingSoon) {
      // Hide the upcoming-entry card whenever any filter is active.
      const filterActive = state.danger !== null || state.tag !== null || state.search.length > 0;
      comingSoon.toggleAttribute('hidden', filterActive);
    }
    if (empty) empty.toggleAttribute('hidden', visible > 0);
  }

  bar?.addEventListener('click', (event) => {
    const target = (event.target as HTMLElement).closest<HTMLElement>('[data-filter]');
    if (!target) return;

    const filter = target.dataset.filter as 'danger' | 'tag';
    const value = target.dataset.value;

    if (filter === 'danger') {
      state.danger =
        value === 'all'
          ? null
          : { min: Number(target.dataset.min), max: Number(target.dataset.max) };
    } else if (filter === 'tag') {
      state.tag = value === 'all' ? null : (value ?? null);
    }

    bar.querySelectorAll<HTMLElement>(`[data-filter="${filter}"]`).forEach((chip) => {
      chip.classList.toggle('is-active', chip === target);
    });

    applyFilters();
  });

  // Tag-list expand/collapse — toggle hidden on every "rest" chip at once.
  tagToggle?.addEventListener('click', () => {
    if (tagRestChips.length === 0) return;
    const wasHidden = tagRestChips[0].hasAttribute('hidden');
    tagRestChips.forEach((chip) => chip.toggleAttribute('hidden', !wasHidden));
    tagToggle.setAttribute('aria-expanded', String(wasHidden));
    tagToggleShow?.toggleAttribute('hidden', wasHidden);
    tagToggleHide?.toggleAttribute('hidden', !wasHidden);
  });

  // Search input.
  searchInput?.addEventListener('input', () => {
    state.search = searchInput.value.trim().toLowerCase();
    searchClear?.toggleAttribute('hidden', state.search.length === 0);
    applyFilters();
  });

  searchClear?.addEventListener('click', () => {
    if (!searchInput) return;
    searchInput.value = '';
    state.search = '';
    searchClear.toggleAttribute('hidden', true);
    applyFilters();
    searchInput.focus();
  });

  document.querySelector('[data-filter-clear]')?.addEventListener('click', () => {
    state.danger = null;
    state.tag = null;
    state.search = '';
    if (searchInput) searchInput.value = '';
    searchClear?.toggleAttribute('hidden', true);
    bar?.querySelectorAll<HTMLElement>('[data-filter]').forEach((chip) => {
      chip.classList.toggle('is-active', chip.dataset.value === 'all');
    });
    applyFilters();
  });
</script>
