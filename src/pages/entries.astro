---
import FieldManual from '../layouts/FieldManual.astro';
import StampRow from '../components/StampRow.astro';
import DocMeta from '../components/DocMeta.astro';
import DocTitle from '../components/DocTitle.astro';
import { loadMonsterEntries } from '../lib/monsters.ts';
import { upcoming } from '../config/site.ts';
import '../styles/pages/entries.css';

// Auto-discover every monster page that exports an `entry`.
// To add a new monster: create the page file with that export. No edit here.
const modules = import.meta.glob<{ entry?: import('../lib/monsters.ts').MonsterEntry }>(
  './*.astro',
  { eager: true },
);
const entries = loadMonsterEntries(modules);
---

<FieldManual
  title="Monster Index"
  description="Every Monster Survival Guide entry filed so far. Start anywhere. Read everything."
  classification="monster survival guide  —  menu"
  bottomBar="monster survival guide  ·  all entries  ·  season one"
>
  <StampRow red="All Entries" faded="Season One" blue="Field Manual" />
  <DocMeta
    rows={[
      { label: 'DOCUMENT TYPE', value: 'Index — All Survival Guide Journal Entries' },
      { label: 'SEASON', value: 'One — Currently Active' },
      { label: 'ENTRIES', value: `${entries.length} Filed — More Incoming` },
      { label: 'STATUS', value: 'Open Distribution — Read Before You Need To' },
    ]}
  />
  <DocTitle subtitle="Every survival guide filed so far. Start anywhere. Read everything.">
    All<br />Entries
  </DocTitle>

  <h2 class="section-head">Start Here</h2>
  <div class="entry-list">
    <a class="entry-card about" href="/">
      <div class="entry-band" style="background: rgba(26,22,16,0.25);"></div>
      <div class="entry-body">
        <div class="entry-label">Introduction · Field Manual</div>
        <h3 class="entry-title">About This Guide</h3>
        <div class="entry-desc">
          What this is, how it works, and why you should read it before you need it.
        </div>
        <div class="entry-meta">
          <span class="entry-tag">How to use</span>
          <span class="entry-tag">Danger index explained</span>
          <span class="entry-tag">Season one overview</span>
        </div>
      </div>
      <div class="entry-right">
        <div class="mini-index">
          <div class="mini-label">No threat entity</div>
        </div>
        <div class="entry-arrow">→</div>
      </div>
    </a>
  </div>

  <hr class="divider" />

  <h2 class="section-head">Season One — Survival Entries</h2>
  <div class="entry-list">
    {
      entries.map((e) => (
        <a class="entry-card" href={e.url}>
          <div class="entry-band" style={`background: ${e.bandColor};`} />
          <div class="entry-body">
            <div class="entry-label">
              Entry {e.number} · {e.entryClass} · {e.region}
            </div>
            <h3 class="entry-title">{e.title}</h3>
            <div class="entry-desc">{e.description}</div>
            <div class="entry-meta">
              {e.tags.map((t) => (
                <span class="entry-tag">{t}</span>
              ))}
            </div>
          </div>
          <div class="entry-right">
            <div class="mini-index">
              <div class="mini-label">Danger · {e.danger}/10</div>
              <div class="mini-bars" role="img" aria-label={`Danger ${e.danger} out of 10`}>
                {Array.from({ length: 10 }).map((_, i) => (
                  <div class={i < e.danger ? 'mbar f' : 'mbar'} aria-hidden="true" />
                ))}
              </div>
            </div>
            <div class="entry-arrow">→</div>
          </div>
        </a>
      ))
    }

    {
      upcoming && (
        <div class="entry-card coming-soon">
          <div class="entry-band" style="background: rgba(26,22,16,0.2);" />
          <div class="entry-body">
            <div class="entry-label">{upcoming.label}</div>
            <h3 class="entry-title">{upcoming.title}</h3>
            <div class="entry-desc">{upcoming.description}</div>
            <div class="entry-meta">
              <span class="entry-tag">Pending</span>
            </div>
          </div>
          <div class="entry-right">
            <div class="mini-index">
              <div class="mini-label">Classified</div>
              <div class="mini-bars" aria-hidden="true">
                {Array.from({ length: 10 }).map(() => (
                  <div class="mbar" />
                ))}
              </div>
            </div>
            <div class="entry-arrow" style="opacity:0.2;">
              →
            </div>
          </div>
        </div>
      )
    }
  </div>
</FieldManual>
