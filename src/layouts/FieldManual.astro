---
import '../styles/field-manual.css';

// Self-hosted fonts via @fontsource — no Google Fonts CDN, no preconnect needed.
import '@fontsource/rajdhani/400.css';
import '@fontsource/rajdhani/500.css';
import '@fontsource/rajdhani/600.css';
import '@fontsource/rajdhani/700.css';
import '@fontsource/sorts-mill-goudy/400.css';
import '@fontsource/sorts-mill-goudy/400-italic.css';
import '@fontsource/anonymous-pro/400.css';
import '@fontsource/anonymous-pro/400-italic.css';

import { site, cloudflareAnalyticsToken } from '../config/site.ts';
import SocialRow from '../components/SocialRow.astro';
import { siteGraph, articleGraph, type ArticleSchemaInput } from '../lib/structured-data.ts';

interface Props {
  /** Browser tab title (used in <title>) */
  title: string;
  /** SEO/social meta description. Falls back to the site default. */
  description?: string;
  /** Text shown in the dark bar at the top of the document. */
  classification: string;
  /** Text shown in the dark bar at the bottom of the document. Defaults to the classification text. */
  bottomBar?: string;
  /** Status badge text in the bottom-right of the sign-off block. */
  status?: string;
  /**
   * Path-relative to the site root, used to build the canonical / og:url.
   * Defaults to the current Astro request pathname.
   */
  pathname?: string;
  /** Open Graph image. Defaults to the site's default OG image. */
  ogImage?: string;
  /**
   * When set, the page emits Article structured data (in addition to the
   * site-wide Person + WebSite graph). Pass on monster entry pages.
   */
  article?: Pick<ArticleSchemaInput, 'datePublished' | 'dateModified'>;
}

const {
  title,
  description = site.description,
  classification,
  bottomBar,
  status = 'Active',
  pathname,
  ogImage = site.defaultOgImage,
  article,
} = Astro.props;

const bottomText = bottomBar ?? classification;
const canonical = new URL(pathname ?? Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
const fullTitle = title === site.name ? title : `${title} — ${site.name}`;

const jsonLd = article
  ? articleGraph({
      headline: title,
      description,
      url: canonical,
      image: ogImageUrl,
      ...article,
    })
  : siteGraph();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    {/* Open Graph */}
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.name} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <meta name="theme-color" content="#1a1610" />

    <link rel="alternate" type="application/rss+xml" title={`${site.name} — RSS`} href="/rss.xml" />

    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="document">
      <div class="classification-bar" aria-hidden="true">
        ◆ &nbsp; <Fragment set:html={classification} /> &nbsp; ◆
      </div>

      <main id="main-content" class="doc-inner" tabindex="-1">
        <slot />

        <footer class="sign-off-block">
          <div class="sig-left">
            {site.name}<br />
            <span class="sig-name">{site.signature}</span>
            <span class="sig-tagline">{site.tagline}</span>
            <SocialRow />
          </div>

          <div class="sig-right">
            Classification: Open<br />
            Distribution: Unrestricted<br />
            Status: <span class="status-badge">{status}</span>
          </div>
        </footer>
      </main>

      <div class="bottom-bar" aria-hidden="true">
        ◆ &nbsp; <Fragment set:html={bottomText} /> &nbsp; ◆
      </div>
    </div>

    {
      cloudflareAnalyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cloudflareAnalyticsToken}"}`}
        />
      )
    }
  </body>
</html>
