---
import '../styles/field-manual.css';
import { site } from '../config/site.ts';
import SocialRow from '../components/SocialRow.astro';

interface Props {
  /** Browser tab title (used in <title>) */
  title: string;
  /** SEO/social meta description. Falls back to the site default. */
  description?: string;
  /** Text shown in the dark bar at the top of the document. */
  classification: string;
  /** Text shown in the dark bar at the bottom of the document. Defaults to the classification text. */
  bottomBar?: string;
  /** Status badge text in the bottom-right of the sign-off block. */
  status?: string;
  /**
   * Path-relative to the site root, used to build the canonical / og:url.
   * Defaults to the current Astro request pathname.
   */
  pathname?: string;
  /** Open Graph image. Defaults to the site's default OG image. */
  ogImage?: string;
}

const {
  title,
  description = site.description,
  classification,
  bottomBar,
  status = 'Active',
  pathname,
  ogImage = site.defaultOgImage,
} = Astro.props;

const bottomText = bottomBar ?? classification;
const canonical = new URL(pathname ?? Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
const fullTitle = title === site.name ? title : `${title} — ${site.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.name} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <meta name="theme-color" content="#1a1610" />

    {/* Fonts — preconnect saves a round-trip on first paint */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Sorts+Mill+Goudy:ital@0;1&family=Anonymous+Pro:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="document">
      <div class="classification-bar">
        ◆ &nbsp; <Fragment set:html={classification} /> &nbsp; ◆
      </div>

      <main class="doc-inner">
        <slot />

        <footer class="sign-off-block">
          <div class="sig-left">
            {site.name}<br />
            <span class="sig-name">{site.signature}</span>
            <span class="sig-tagline">{site.tagline}</span>
            <SocialRow />
          </div>

          <div class="sig-right">
            Classification: Open<br />
            Distribution: Unrestricted<br />
            Status: <span class="status-badge">{status}</span>
          </div>
        </footer>
      </main>

      <div class="bottom-bar">
        ◆ &nbsp; <Fragment set:html={bottomText} /> &nbsp; ◆
      </div>
    </div>
  </body>
</html>
