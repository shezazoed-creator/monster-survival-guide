---
import '../styles/field-manual.css';

// =====================================================================
//  SOCIAL MEDIA URLS
//  Update each value here when you have your real link.
//  These show up in the footer of every page automatically.
//  Tip: keep '#' as the placeholder — clicking does nothing, no broken link.
// =====================================================================
const SOCIAL = {
  youtube:   '#',
  facebook:  '#',
  instagram: '#',
  x:         '#',
  tiktok:    '#',
};

interface Props {
  /** Browser tab title (used in <title>) */
  title: string;
  /** Text shown in the dark bar at the top of the document. Diamonds and spacing are added automatically. */
  classification: string;
  /** Text shown in the dark bar at the bottom of the document. Defaults to the classification text. */
  bottomBar?: string;
  /** Status badge text in the bottom-right of the sign-off block. Defaults to "Active". */
  status?: string;
}

const {
  title,
  classification,
  bottomBar,
  status = 'Active',
} = Astro.props;
const bottomText = bottomBar ?? classification;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Sorts+Mill+Goudy:ital@0;1&family=Anonymous+Pro:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="document">
      <div class="classification-bar">
        ◆ &nbsp; <Fragment set:html={classification} /> &nbsp; ◆
      </div>

      <div class="doc-inner">
        <slot />

        {/* ── shared footer / sign-off block ─────────────────────────── */}
        <div class="sign-off-block">
          <div class="sig-left">
            Monster Survival Guide<br />
            <span class="sig-name">Zazu</span>
            <span class="sig-tagline">Identification · Survival · Documented Accounts</span>

            <div class="social-row">
              <a href={SOCIAL.youtube} class="social-btn" aria-label="YouTube">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z" /></svg>
              </a>
              <a href={SOCIAL.facebook} class="social-btn" aria-label="Facebook">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.88v2.27h3.32l-.53 3.5h-2.79V24C19.61 23.1 24 18.1 24 12.07z" /></svg>
              </a>
              <a href={SOCIAL.instagram} class="social-btn" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85 0 3.2-.01 3.58-.07 4.85-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07-3.2 0-3.58-.01-4.85-.07-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12c0-3.2.01-3.58.07-4.85C2.38 3.85 3.9 2.31 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 2.7.27.27 2.7.07 7.05.01 8.33 0 8.74 0 12c0 3.26.01 3.67.07 4.95.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24c3.26 0 3.67-.01 4.95-.07 4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95 0-3.26-.01-3.67-.07-4.95-.2-4.35-2.63-6.78-6.98-6.98C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32A6.16 6.16 0 0 0 12 5.84zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z" /></svg>
              </a>
              <a href={SOCIAL.x} class="social-btn" aria-label="X">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 2h3.28l-7.17 8.2L22.79 22h-6.6l-5.17-6.76L4.84 22H1.55l7.67-8.77L1.2 2h6.77l4.67 6.18zm-1.15 18h1.82L6.99 3.84H5.04z" /></svg>
              </a>
              <a href={SOCIAL.tiktok} class="social-btn" aria-label="TikTok">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z" /></svg>
              </a>
            </div>
          </div>

          <div class="sig-right">
            Classification: Open<br />
            Distribution: Unrestricted<br />
            Status: <span class="status-badge">{status}</span>
          </div>
        </div>
      </div>

      <div class="bottom-bar">
        ◆ &nbsp; <Fragment set:html={bottomText} /> &nbsp; ◆
      </div>
    </div>

    <style>
      .sig-tagline {
        font-family: 'Anonymous Pro', monospace;
        font-size: 0.58rem;
        color: var(--margin);
      }
      .status-badge {
        color: var(--warn);
      }
    </style>
  </body>
</html>
