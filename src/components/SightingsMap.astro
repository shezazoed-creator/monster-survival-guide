---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'monsters'>[];
}
const { entries } = Astro.props;

// Stylised North America outline. Hand-drawn for the field-manual aesthetic;
// not a real geographic projection. Coordinates assume the 1000×600 viewBox.
const NORTH_AMERICA_PATH =
  'M 220 95 L 300 60 L 500 50 L 700 55 L 810 75 ' +
  'L 850 130 L 870 195 L 855 240 L 820 275 L 800 320 ' +
  'L 770 380 L 740 440 L 720 480 L 680 480 L 640 470 ' +
  'L 540 465 L 440 460 L 380 470 L 330 510 L 290 545 ' +
  'L 255 575 L 235 555 L 230 500 L 215 460 L 180 420 ' +
  'L 145 360 L 125 280 L 135 220 L 165 165 L 200 115 Z';

const pinned = entries.filter((e) => e.data.coords);
---

<div class="map-frame">
  <svg
    class="map-svg"
    viewBox="0 0 1000 600"
    role="img"
    aria-label="Stylised map of North America with pins for each Monster Survival Guide entry."
  >
    {/* Background grid for the field-manual feel */}
    <g class="map-grid" aria-hidden="true">
      {Array.from({ length: 11 }).map((_, i) => <line x1={i * 100} y1={0} x2={i * 100} y2={600} />)}
      {Array.from({ length: 7 }).map((_, i) => <line x1={0} y1={i * 100} x2={1000} y2={i * 100} />)}
    </g>

    {/* Land mass */}
    <path class="map-land" d={NORTH_AMERICA_PATH}></path>

    {/* Pins */}
    {
      pinned.map((entry) => {
        const { x, y, label } = entry.data.coords!;
        const text = label ?? entry.data.title;
        return (
          <a
            class="map-pin-link"
            href={`/${entry.id}`}
            aria-label={`${entry.data.title} — ${entry.data.region}`}
          >
            <circle class="map-pin" cx={x} cy={y} r={11} />
            <text class="map-pin-label" x={x + 18} y={y + 4} dominant-baseline="middle">
              {`${entry.data.number} ${entry.data.title}`}
            </text>
            <title>{`${entry.data.title} — ${text}`}</title>
          </a>
        );
      })
    }
  </svg>
</div>
