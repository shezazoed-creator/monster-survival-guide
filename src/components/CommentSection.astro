---
/**
 * Comments + reactions widget. Talks to the Pages Function at
 * /api/posts/<slug>/comments — same origin, no third-party JS, no GitHub
 * login required.
 *
 * Posting is open by default (no auth). The Pages Function rate-limits
 * per-IP, validates length, and runs a honeypot check for bots.
 * Set COMMENTS_REQUIRE_APPROVAL=1 in the Pages env to gate every
 * comment behind moderation; pending comments don't appear in GET.
 */
interface Props {
  /** URL slug for this post — used as the comment scope. */
  slug: string;
}
const { slug } = Astro.props;
---

<section
  class="comments"
  aria-labelledby={`comments-${slug}`}
  data-comments-section
  data-slug={slug}
>
  <h2 class="section-head" id={`comments-${slug}`}>Comments</h2>
  <p class="comments-blurb">
    No login required. Be civil; corrections especially welcome. Comments are rate-limited and
    lightly moderated — abuse, spam, or anything tipping into harassment gets removed.
  </p>

  <ol class="comments-list" data-comments-list aria-live="polite">
    <li class="comments-loading" data-comments-loading>Loading comments…</li>
  </ol>

  <p class="comments-empty" data-comments-empty hidden>No comments yet — be the first.</p>

  <p class="comments-error" data-comments-error hidden role="alert"></p>

  <form class="comments-form" data-comments-form novalidate>
    <div class="comments-form-row">
      <label class="comments-field">
        <span class="comments-label">Name</span>
        <input
          name="author"
          type="text"
          required
          minlength="1"
          maxlength="80"
          autocomplete="nickname"
          placeholder="Your name (or a handle)"
        />
      </label>
    </div>
    <label class="comments-field">
      <span class="comments-label">Comment</span>
      <textarea
        name="body"
        required
        minlength="1"
        maxlength="5000"
        rows="4"
        placeholder="Stay on topic. Cite sources where you can."></textarea>
    </label>
    {
      /* Honeypot: visually hidden + aria-hidden + tab-skipped. Bots fill it,
        humans don't. */
    }
    <label class="comments-honeypot" aria-hidden="true">
      Website
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
    <button type="submit" class="comments-submit" data-comments-submit> Post comment </button>
    <p class="comments-status" data-comments-status></p>
  </form>
</section>

<style>
  .comments {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
  }

  .comments-blurb {
    font-family: 'Sorts Mill Goudy', Georgia, serif;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--faded);
    margin: 0 0 24px;
  }

  .comments-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .comments-list li {
    border-left: 3px solid var(--rule);
    padding: 4px 0 4px 14px;
  }

  .comments-list li.is-new {
    border-left-color: var(--warn);
  }

  .comment-author {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    color: var(--ink);
    text-transform: uppercase;
    margin-right: 10px;
  }

  .comment-time {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: var(--margin);
    text-transform: uppercase;
  }

  .comment-body {
    font-family: 'Sorts Mill Goudy', Georgia, serif;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink);
    margin: 6px 0 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .comments-loading,
  .comments-empty {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.7rem;
    color: var(--margin);
    letter-spacing: 0.1em;
  }

  .comments-error {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.7rem;
    color: var(--warn);
    border: 1px solid color-mix(in srgb, var(--warn) 30%, transparent);
    background: color-mix(in srgb, var(--warn) 4%, transparent);
    padding: 10px 14px;
  }

  .comments-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    border: 1px solid var(--rule);
    background: color-mix(in srgb, var(--ink) 3%, transparent);
    padding: 18px 20px;
  }

  .comments-form-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .comments-form-row > .comments-field {
    flex: 1;
    min-width: 200px;
  }

  .comments-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .comments-label {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    color: var(--margin);
    text-transform: uppercase;
  }

  .comments-form input[type='text'],
  .comments-form textarea {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.85rem;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 8px 10px;
    resize: vertical;
  }

  .comments-form input[type='text']:focus,
  .comments-form textarea:focus {
    outline: 2px solid var(--warn);
    outline-offset: 1px;
    border-color: var(--ink);
  }

  .comments-honeypot {
    position: absolute !important;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .comments-submit {
    align-self: flex-start;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border: 1px solid var(--ink);
    padding: 8px 18px;
    cursor: pointer;
  }

  .comments-submit:hover,
  .comments-submit:focus-visible {
    background: var(--warn);
    border-color: var(--warn);
    outline: none;
  }

  .comments-submit:disabled {
    opacity: 0.5;
    cursor: progress;
  }

  .comments-status {
    font-family: 'Anonymous Pro', monospace;
    font-size: 0.65rem;
    color: var(--margin);
    margin: 0;
    min-height: 1em;
  }

  .comments-status[data-state='success'] {
    color: var(--ink);
  }
  .comments-status[data-state='error'] {
    color: var(--warn);
  }
</style>

<script>
  type Comment = { id: number; author: string; body: string; created_at: string };

  const sections = document.querySelectorAll<HTMLElement>('[data-comments-section]');
  for (const section of Array.from(sections)) hydrate(section);

  function hydrate(section: HTMLElement) {
    const slug = section.dataset.slug ?? '';
    const list = section.querySelector<HTMLOListElement>('[data-comments-list]')!;
    const loading = section.querySelector<HTMLElement>('[data-comments-loading]')!;
    const emptyEl = section.querySelector<HTMLElement>('[data-comments-empty]')!;
    const errorEl = section.querySelector<HTMLElement>('[data-comments-error]')!;
    const form = section.querySelector<HTMLFormElement>('[data-comments-form]')!;
    const submit = section.querySelector<HTMLButtonElement>('[data-comments-submit]')!;
    const status = section.querySelector<HTMLElement>('[data-comments-status]')!;

    const fmt = new Intl.DateTimeFormat(undefined, {
      dateStyle: 'medium',
      timeStyle: 'short',
    });

    function render(comments: Comment[], opts: { newId?: number } = {}) {
      list.replaceChildren();
      if (comments.length === 0) {
        emptyEl.hidden = false;
        return;
      }
      emptyEl.hidden = true;
      for (const c of comments) {
        const li = document.createElement('li');
        if (opts.newId === c.id) li.classList.add('is-new');
        // created_at from D1 is "YYYY-MM-DD HH:MM:SS" UTC; treat as UTC.
        const iso = c.created_at.includes('T')
          ? c.created_at
          : c.created_at.replace(' ', 'T') + 'Z';
        const date = new Date(iso);

        const meta = document.createElement('div');
        const author = document.createElement('span');
        author.className = 'comment-author';
        author.textContent = c.author;
        const time = document.createElement('time');
        time.className = 'comment-time';
        time.dateTime = iso;
        time.textContent = fmt.format(date);
        meta.append(author, time);

        const body = document.createElement('p');
        body.className = 'comment-body';
        body.textContent = c.body;

        li.append(meta, body);
        list.append(li);
      }
    }

    async function load() {
      try {
        const res = await fetch(`/api/posts/${slug}/comments`, {
          headers: { accept: 'application/json' },
        });
        if (!res.ok) throw new Error(`server returned ${res.status}`);
        const data = (await res.json()) as { comments: Comment[] };
        loading.remove();
        render(data.comments);
      } catch (err) {
        loading.remove();
        errorEl.hidden = false;
        errorEl.textContent =
          'Couldn’t load comments right now. The site is fine; the comments service may not be deployed yet, or you might be offline.';
      }
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const author = String(formData.get('author') ?? '').trim();
      const body = String(formData.get('body') ?? '').trim();
      const website = String(formData.get('website') ?? '');

      if (!author || !body) {
        status.dataset.state = 'error';
        status.textContent = 'Name and comment are required.';
        return;
      }

      submit.disabled = true;
      status.dataset.state = '';
      status.textContent = 'Posting…';

      try {
        const res = await fetch(`/api/posts/${slug}/comments`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ author, body, website }),
        });
        const data = (await res.json()) as {
          ok?: boolean;
          comment?: Comment;
          pending?: boolean;
          error?: string;
          spam?: boolean;
        };
        if (!res.ok || data.error) {
          throw new Error(data.error ?? `server returned ${res.status}`);
        }
        if (data.pending) {
          status.dataset.state = 'success';
          status.textContent = 'Submitted — your comment is pending approval.';
        } else if (data.spam) {
          // Honeypot tripped. Pretend success; do nothing.
          status.dataset.state = 'success';
          status.textContent = 'Submitted.';
        } else if (data.comment) {
          // Append optimistically and clear the form.
          const current = Array.from(list.children).map((li): Comment => {
            const id = Number(li.getAttribute('data-id') ?? 0);
            return {
              id,
              author: li.querySelector('.comment-author')?.textContent ?? '',
              body: li.querySelector('.comment-body')?.textContent ?? '',
              created_at: li.querySelector('time')?.dateTime ?? '',
            };
          });
          render([...current, data.comment], { newId: data.comment.id });
          status.dataset.state = 'success';
          status.textContent = 'Posted.';
        }
        form.reset();
      } catch (err) {
        status.dataset.state = 'error';
        status.textContent =
          err instanceof Error ? err.message : 'Something went wrong. Try again in a moment.';
      } finally {
        submit.disabled = false;
      }
    });

    load();
  }
</script>
